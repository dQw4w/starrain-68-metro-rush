# Local dev (matches docker-compose.yml's `db` service):
DATABASE_URL=postgresql://metro_rush:metro_rush@localhost:5433/metro_rush

# Production: use your Supabase project's "Session pooler" or direct connection
# string (Project Settings → Database → Connection string), NOT the "Transaction
# pooler" — asyncpg's server-side prepared statements are incompatible with it.
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-xxxx.pooler.supabase.com:5432/postgres

# Bootstrap PIN for the single super-admin account, seeded on first startup.
# Change this before a real event.
SUPERADMIN_BOOTSTRAP_PIN=0000

SESSION_TTL_HOURS=18
WS_TICKET_TTL_SECONDS=30
