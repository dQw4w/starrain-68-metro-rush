# Local dev (matches docker-compose.yml's `db` service):
DATABASE_URL=postgresql://metro_rush:metro_rush@localhost:5433/metro_rush

# Production: use your Supabase project's POOLER connection string (Project
# Settings → Database → Connection string → "Session pooler" or "Transaction
# pooler", host contains "pooler.supabase.com"), NOT the "Direct connection"
# string (host db.<ref>.supabase.co) — the direct string resolves IPv6-only,
# which most hosts (Render, Railway, etc.) can't route to and fails with
# "Network is unreachable". The pooler host is IPv4-compatible. Either pooler
# mode works here — db.py already sets statement_cache_size=0, which is what
# the "Transaction pooler" needs to be compatible with asyncpg.
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-xxxx.pooler.supabase.com:6543/postgres

# Bootstrap PIN for the single super-admin account, seeded on first startup.
# Change this before a real event.
SUPERADMIN_BOOTSTRAP_PIN=0000

SESSION_TTL_HOURS=18
WS_TICKET_TTL_SECONDS=30
